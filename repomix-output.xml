  </div>
  <canvas id="game" width="360" height="540"></canvas>
  <div id="hint">Use ← / → (or A / D) to steer. Avoid the oncoming cars.</div>
  <button id="restart" hidden>Restart</button>

  <script>
    const canvas = document.getElementById("game");
    const ctx = canvas.getContext("2d");
    const scoreEl = document.getElementById("score");
    const bestEl = document.getElementById("best");
    const restartBtn = document.getElementById("restart");

    const W = canvas.width;
    const H = canvas.height;
    const LANES = 3;
    const LANE_W = W / LANES;

    let player, obstacles, speed, score, best, running, lastSpawn, keys;

    best = Number(localStorage.getItem("vibin-car-best") || 0);
    bestEl.textContent = best;

    function reset() {
