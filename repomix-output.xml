      const lane = Math.floor(Math.random() * LANES);
      obstacles.push({ lane, y: -80, w: 40, h: 70 });
    }

    function laneCenter(lane) {
      return lane * LANE_W + LANE_W / 2;
    }

    function drawCar(x, y, w, h, color) {
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.roundRect(x - w / 2, y - h / 2, w, h, 8);
      ctx.fill();
      ctx.fillStyle = "rgba(255,255,255,0.15)";
      ctx.fillRect(x - w / 2 + 6, y - h / 2 + 8, w - 12, h - 16);
    }

    function update() {
      if (!running) return;

      if (keys["ArrowLeft"] || keys["a"] || keys["A"]) player.lane = Math.max(0, player.lane - 0.08);
      if (keys["ArrowRight"] || keys["d"] || keys["D"]) player.lane = Math.min(LANES - 1, player.lane + 0.08);

      // smooth lane-to-lane handled above; allow integer snapping feel via rounding for collision
      speed += 0.002;
      score += 0.05;
      scoreEl.textContent = Math.floor(score);

      if (performance.now() - lastSpawn > 900 - Math.min(500, speed * 30)) {
        spawnObstacle();
        lastSpawn = performance.now();
      }

      const px = laneCenter(player.lane);
      for (const o of obstacles) {
        o.y += speed;
        const ox = laneCenter(o.lane);
        if (
          Math.abs(px - ox) < (player.w + o.w) / 2 - 6 &&
          Math.abs(H - 60 - o.y) < (player.h + o.h) / 2 - 6
        ) {
          gameOver();
        }
      }
      obstacles = obstacles.filter((o) => o.y < H + 100);
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      // road
      ctx.fillStyle = "#1c2138";
      ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = "rgba(255,255,255,0.15)";
      ctx.lineWidth = 2;
      ctx.setLineDash([18, 18]);
      for (let i = 1; i < LANES; i++) {
        ctx.beginPath();
        ctx.moveTo(i * LANE_W, 0);
        ctx.lineTo(i * LANE_W, H);
        ctx.stroke();
      }
      ctx.setLineDash([]);

      for (const o of obstacles) {
        drawCar(laneCenter(o.lane), o.y, o.w, o.h, "#e0556b");
      }
      drawCar(laneCenter(player.lane), H - 60, player.w, player.h, "#5ad17a");
    }

    function loop() {
      update();
      draw();
      requestAnimationFrame(loop);
    }

    function gameOver() {
      running = false;
      const finalScore = Math.floor(score);
      if (finalScore > best) {
        best = finalScore;
        localStorage.setItem("vibin-car-best", String(best));
        bestEl.textContent = best;
      }
      ctx.fillStyle = "rgba(0,0,0,0.6)";
      ctx.fillRect(0, H / 2 - 50, W, 100);
      ctx.fillStyle = "#fff";
      ctx.textAlign = "center";
      ctx.font = "24px system-ui, sans-serif";
      ctx.fillText("Game Over", W / 2, H / 2 - 6);
      ctx.font = "16px system-ui, sans-serif";
      ctx.fillText("Score: " + finalScore, W / 2, H / 2 + 22);
      restartBtn.hidden = false;
    }

    window.addEventListener("keydown", (e) => {
      keys[e.key] = true;
      if (["ArrowLeft", "ArrowRight"].includes(e.key)) e.preventDefault();
    });
    window.addEventListener("keyup", (e) => { keys[e.key] = false; });
    restartBtn.addEventListener("click", reset);

    reset();
    loop();
  </script>
</body>
</html>
</file>

