{
  "name": "vibin",
  "version": "0.1.0",
  "description": "A focused, polished coding agent for your terminal.",
  "type": "module",
  "bin": {
    "vibin": "./dist/index.js"
  },
  "files": ["dist/index.js", "README.md", "LICENSE", "NOTICE.md"],
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "smoke": "bun run src/index.ts --smoke",
    "build": "bun build --target=bun --outdir dist --external keytar src/index.ts",
    "verify": "bun run typecheck && bun test && bun run smoke && bun run build",
    "prepublishOnly": "bun run verify",
    "build:windows-setup": "bun build --compile --target=bun-windows-x64 --outfile dist/VibinSetup.exe src/installer.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  }
}
